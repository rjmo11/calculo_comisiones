<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0"> 
        <record id="module_category_calculo_comisiones" model="ir.module.category">
            <field name="name">Cálculo de Comisiones</field>
            <field name="description">Gestión de comisiones para distribuidoras Dimac 21.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_calculo_comisiones_vendedor" model="res.groups">
            <field name="name">Vendedor</field>
            <field name="category_id" ref="module_category_calculo_comisiones"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_calculo_comisiones_supervisor" model="res.groups">
            <field name="name">Supervisor</field>
            <field name="category_id" ref="module_category_calculo_comisiones"/>
            <field name="implied_ids" eval="[(4, ref('group_calculo_comisiones_vendedor'))]"/>
        </record>

        <record id="group_calculo_comisiones_admin" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_calculo_comisiones"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Se reasignan las reglas viejas al nuevo grupo supervisor con comando (6, 0) para limpiarlo limpiamente del administrador -->
        <record id="rule_meta_vendedor_all" model="ir.rule">
            <field name="name">Metas: Supervisor (Equipo)</field>
            <field name="model_id" ref="model_meta_vendedor"/>
            <field name="domain_force">['|', '|', ('vendedor_id.user_id', '=', user.id), ('vendedor_id.parent_id.user_id', '=', user.id), ('vendedor_id.user_id.sale_team_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('group_calculo_comisiones_supervisor')])]"/>
        </record>

        <record id="rule_meta_vendedor_personal" model="ir.rule">
            <field name="name">Metas Personales: Vendedor</field>
            <field name="model_id" ref="model_meta_vendedor"/>
            <field name="domain_force">[('vendedor_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('group_calculo_comisiones_vendedor')])]"/>
        </record>

        <record id="rule_meta_vendedor_admin" model="ir.rule">
            <field name="name">Metas: Administrador</field>
            <field name="model_id" ref="model_meta_vendedor"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('group_calculo_comisiones_admin')])]"/>
        </record>

        <record id="rule_calculo_comision_all" model="ir.rule">
            <field name="name">Cálculos: Supervisor (Equipo)</field>
            <field name="model_id" ref="model_calculo_comision"/>
            <field name="domain_force">['|', '|', ('vendedor_id.user_id', '=', user.id), ('vendedor_id.parent_id.user_id', '=', user.id), ('vendedor_id.user_id.sale_team_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('group_calculo_comisiones_supervisor')])]"/>
        </record>

        <record id="rule_calculo_comision_personal" model="ir.rule">
            <field name="name">Cálculos Personales: Vendedor</field>
            <field name="model_id" ref="model_calculo_comision"/>
            <field name="domain_force">[('vendedor_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(6, 0, [ref('group_calculo_comisiones_vendedor')])]"/>
        </record>

        <record id="rule_calculo_comision_admin" model="ir.rule">
            <field name="name">Cálculos: Administrador</field>
            <field name="model_id" ref="model_calculo_comision"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(6, 0, [ref('group_calculo_comisiones_admin')])]"/>
        </record>
    </data>
</odoo>
<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_calculo_comisiones" model="ir.module.category">
            <field name="name">Cálculo de Comisiones</field>
            <field name="description">Gestión de comisiones para distribuidoras Dimac 21.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_calculo_comisiones_vendedor" model="res.groups">
            <field name="name">Vendedor</field>
            <field name="category_id" ref="module_category_calculo_comisiones"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_calculo_comisiones_admin" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_calculo_comisiones"/>
            <field name="implied_ids" eval="[(4, ref('group_calculo_comisiones_vendedor'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <record id="rule_meta_vendedor_personal" model="ir.rule">
            <field name="name">Metas: Vendedor (Propio)</field>
            <field name="model_id" ref="model_meta_vendedor"/>
            <field name="domain_force">[('vendedor_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_calculo_comisiones_vendedor'))]"/>
        </record>

        <record id="rule_meta_vendedor_supervisor" model="ir.rule">
            <field name="name">Metas: Supervisor (Equipo)</field>
            <field name="model_id" ref="model_meta_vendedor"/>
            <field name="domain_force">['|', ('vendedor_id', '=', user.id), ('vendedor_id.sale_team_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_calculo_comisiones_supervisor'))]"/>
        </record>

        <record id="rule_calculo_comision_vendedor" model="ir.rule">
            <field name="name">Cálculos: Vendedor (Propio)</field>
            <field name="model_id" ref="model_calculo_comision"/>
            <field name="domain_force">[('vendedor_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_calculo_comisiones_vendedor'))]"/>
        </record>

        <record id="rule_calculo_comision_supervisor" model="ir.rule">
            <field name="name">Cálculos: Supervisor (Equipo)</field>
            <field name="model_id" ref="model_calculo_comision"/>
            <field name="domain_force">['|', ('vendedor_id', '=', user.id), ('vendedor_id.sale_team_id.user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_calculo_comisiones_supervisor'))]"/>
        </record>

        <record id="rule_esquema_vendedor" model="ir.rule">
            <field name="name">Esquemas: Vendedor (Solo Lectura)</field>
            <field name="model_id" ref="model_esquema_comision"/>
            <field name="domain_force">[('vendedor_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_calculo_comisiones_vendedor'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_esquema_supervisor" model="ir.rule">
            <field name="name">Esquemas: Supervisor (Gestión Total Propios)</field>
            <field name="model_id" ref="model_esquema_comision"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_calculo_comisiones_supervisor'))]"/>
        </record>

        <record id="rule_all_admin" model="ir.rule">
            <field name="name">Acceso Total: Administrador</field>
            <field name="model_id" ref="model_esquema_comision"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_calculo_comisiones_admin'))]"/>
        </record>

    </data>
</odoo>
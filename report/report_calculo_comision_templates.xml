<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_calculo_comision_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <style>
                        .dotted-row td {
                            border-bottom: 1px dotted #ccc !important;
                            border-top: none !important;
                            padding-top: 8px;
                            padding-bottom: 8px;
                        }
                        .table-header th {
                            background-color: #f8f9fa;
                            border-bottom: 2px solid #333;
                        }
                    </style>
                    <div class="page">
                        
                        <!-- Encabezado -->
                        <div class="row align-items-center mb-4">
                            <div class="col-3">
                                <img t-if="res_company.logo" t-att-src="image_data_uri(res_company.logo)" style="max-height: 80px;" alt="Logo Dimac 21"/>
                            </div>
                            <div class="col-9 text-center">
                                <h3 class="fw-bold mb-0">RECIBO DE CONFORMIDAD DE COMISIONES</h3>
                                <h5 class="text-muted mt-2">
                                    Liquidación del Periodo: <span t-esc="doc.fecha_inicio.strftime('%b %Y').title()"/>
                                    <t t-if="doc.tipo_periodo == 'quincena1'"> - <span class="badge text-bg-warning">1ra Quincena (Meta al 50%)</span></t>
                                    <t t-if="doc.tipo_periodo == 'quincena2'"> - <span class="badge text-bg-info">2da Quincena (Ajuste Mensual)</span></t>
                                </h5>
                            </div>
                        </div>

                        <!-- Cuadro de Empleado -->
                        <div class="card mb-4" style="border: 1px solid #ccc; border-radius: 8px;">
                            <div class="card-body py-2 px-3">
                                <div class="row">
                                    <div class="col-6">
                                        <strong>Nombre:</strong> <span t-field="doc.vendedor_id.name"/><br/>
                                        <strong>Cédula / RIF:</strong> <span t-field="doc.vendedor_id.partner_id.vat"/><br/>
                                        <strong>Cargo:</strong> Vendedor
                                    </div>
                                    <div class="col-6 text-end">
                                        <strong>Referencia:</strong> <span t-field="doc.name"/><br/>
                                        <strong>Fechas:</strong> <span t-field="doc.fecha_inicio"/> a <span t-field="doc.fecha_fin"/><br/>
                                        <strong>Fecha Emisión:</strong> <span t-esc="datetime.datetime.now().strftime('%Y-%m-%d')"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- SECCIÓN 1: Resumen de Cumplimiento -->
                        <h5 class="mt-4 fw-bold" style="border-bottom: 2px solid #333; padding-bottom: 5px;">SECCIÓN 1: Resumen de Cumplimiento</h5>
                        <table class="table table-sm table-borderless mb-4">
                            <thead>
                                <tr class="table-header" style="font-size: 13px;">
                                    <th>Concepto</th>
                                    <th class="text-end">Meta Mensual</th>
                                    <th class="text-end">Meta Periodo</th>
                                    <th class="text-end">Logro Realizado</th>
                                    <th class="text-center">% Cumplimiento</th>
                                    <th class="text-end">Bono a Pagar</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="dotted-row" style="font-size: 12px;">
                                    <td><strong>Ventas</strong></td>
                                    <td class="text-end"><span t-field="doc.meta_venta"/></td>
                                    <td class="text-end"><span t-field="doc.meta_venta_aplicada"/></td>
                                    <td class="text-end"><span t-field="doc.venta_real_monto"/></td>
                                    <td class="text-center"><span t-esc="'%.2f' % (doc.porcentaje_cumplimiento_v * 100)"/> %</td>
                                    <td class="text-end"><span t-field="doc.monto_bono_venta"/></td>
                                </tr>
                                <tr class="dotted-row" style="font-size: 12px;">
                                    <td><strong>Cobranzas</strong></td>
                                    <td class="text-end"><span t-field="doc.meta_cobranza"/></td>
                                    <td class="text-end"><span t-field="doc.meta_cobranza_aplicada"/></td>
                                    <td class="text-end"><span t-field="doc.cobranza_real_monto"/></td>
                                    <td class="text-center"><span t-esc="'%.2f' % (doc.porcentaje_cumplimiento_c * 100)"/> %</td>
                                    <td class="text-end"><span t-field="doc.monto_bono_cobranza"/></td>
                                </tr>
                            </tbody>
                        </table>

                        <div style="page-break-inside: auto;"/>

                        <!-- SECCIÓN 2: Detalle de Documentos -->
                        <h5 class="mt-4 fw-bold" style="border-bottom: 2px solid #333; padding-bottom: 5px;">SECCIÓN 2: Detalle de Documentos</h5>
                        
                        <!-- Subsección A: Facturas -->
                        <div class="mb-4">
                            <h6 class="text-primary fw-bold">A. Detalle de Facturas de Venta</h6>
                            <table class="table table-sm mb-1" style="font-size: 13px;">
                                <thead style="display: table-header-group;">
                                    <tr>
                                        <th>Fecha</th>
                                        <th>Número de Factura</th>
                                        <th t-if="doc.is_supervisor_role">Vendedor</th>
                                        <th>Cliente</th>
                                        <th class="text-end">Base Imponible (Venta)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.factura_ids" t-as="inv">
                                        <tr class="dotted-row">
                                            <td><span t-field="inv.invoice_date"/></td>
                                            <td><span t-field="inv.name"/></td>
                                            <td t-if="doc.is_supervisor_role"><span t-field="inv.invoice_user_id.name"/></td>
                                            <td><span t-field="inv.partner_id.name"/></td>
                                            <td class="text-end"><span t-field="inv.amount_untaxed" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </t>
                                    <tr>
                                        <td t-att-colspan="doc.is_supervisor_role and 4 or 3" class="text-end pt-3"><strong>Subtotal de Venta Realizada:</strong></td>
                                        <td class="text-end pt-3 text-primary fw-bold"><strong><span t-field="doc.venta_real_monto"/></strong></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Subsección B: Cobranzas -->
                        <div class="mb-4">
                            <h6 class="text-success fw-bold">B. Detalle de Cobranzas Realizadas</h6>
                            <table class="table table-sm mb-1" style="font-size: 13px;">
                                <thead style="display: table-header-group;">
                                    <tr>
                                        <th>Fecha Pago</th>
                                        <th>Doc. Cobro</th>
                                        <th t-if="doc.is_supervisor_role">Cobrador/Vendedor</th>
                                        <th>Cliente</th>
                                        <th>Factura Relacionada</th>
                                        <th class="text-end">Monto Cobrado</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.pago_ids" t-as="pago">
                                        <tr class="dotted-row">
                                            <td><span t-field="pago.date"/></td>
                                            <td><span t-field="pago.name"/></td>
                                            <!-- Validamos el responsable del cobro: Primero el vendedor asignado, o quien creó el pago -->
                                            <td t-if="doc.is_supervisor_role"><span t-esc="pago.vendedor_id.name or pago.create_uid.name"/></td>
                                            <td><span t-field="pago.partner_id.name"/></td>
                                            <td><span t-esc="', '.join(pago.reconciled_invoice_ids.mapped('name'))"/></td>
                                            <td class="text-end"><span t-field="pago.amount" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/></td>
                                        </tr>
                                    </t>
                                    <tr>
                                        <td t-att-colspan="doc.is_supervisor_role and 5 or 4" class="text-end pt-3"><strong>Subtotal de Cobranza Registrada:</strong></td>
                                        <td class="text-end pt-3 text-success fw-bold"><strong><span t-field="doc.cobranza_real_monto"/></strong></td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- SECCIÓN 3: Totalización -->
                        <div class="row mt-5 mb-5 align-items-center" style="background-color: #f8f9fa; padding: 20px; border-radius: 8px; border: 1px solid #dee2e6;">
                            <div class="col-8">
                                <h4 class="mb-0 fw-bold">MONTO TOTAL A PAGAR</h4>
                            </div>
                            <div class="col-4 text-end">
                                <h2 class="mb-0 fw-bold text-dark"><span t-field="doc.total_a_pagar"/></h2>
                            </div>
                        </div>

                        <!-- SECCIÓN 4: Firmas -->
                        <p class="mt-5 text-justify" style="font-size: 13px; color: #444;">
                            <em>Declaro haber recibido a mi entera satisfacción el monto detallado en este recibo, producto de los cálculos de mi remuneración variable. Firmo en señal de conformidad con los datos antes descritos.</em>
                        </p>

                        <div class="row mt-5 pt-3">
                            <div class="col-6 text-center">
                                <div style="border-top: 1px solid black; width: 80%; margin: 0 auto; padding-top: 5px;">
                                    <strong>Firma del Trabajador</strong><br/>
                                    <span>C.I. <span t-field="doc.vendedor_id.partner_id.vat"/></span>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div style="border-top: 1px solid black; width: 80%; margin: 0 auto; padding-top: 5px;">
                                    <strong>Recibido por Empresa</strong><br/>
                                    <span>Sello / Firma</span>
                                </div>
                            </div>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

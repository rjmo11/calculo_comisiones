<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Filtro Búsqueda para el Dashboard (Por Defecto Mes Actual) -->
        <record id="view_dashboard_comision_search" model="ir.ui.view">
            <field name="name">dashboard.comision.search</field>
            <field name="model">meta.vendedor</field>
            <field name="arch" type="xml">
                <search string="Buscar en Dashboard">
                    <!-- Evalúa context_today(), str() y time -->
                    <filter string="Mes en Curso" name="current_month" 
                        domain="[('is_current_month', '=', True)]"/>
                    <group expand="0" string="Agrupar por">
                        <filter string="Vendedor" name="group_vendedor" context="{'group_by':'vendedor_id'}"/>
                    </group>
                    <!-- Panel Izquierdo de Filtrado Rápido (Pestañas) -->
                    <searchpanel>
                        <field name="periodo_mes" icon="fa-calendar-o" select="multi" enable_counters="1" string="Mes"/>
                    </searchpanel>
                </search>
            </field>
        </record>

        <!-- Kanban View for Dashboard -->
        <record id="view_dashboard_comision_kanban" model="ir.ui.view">
            <field name="name">dashboard.comision.kanban</field>
            <field name="model">meta.vendedor</field>
            <field name="arch" type="xml">
                <kanban create="0" edit="0" class="o_kanban_dashboard o_kanban_dashboard_comision">
                    <field name="vendedor_id"/>
                    <field name="moneda_id"/>
                    <field name="meta_venta"/>
                    <field name="venta_real_actual"/>
                    <field name="progreso_venta_pct"/>
                    <field name="meta_cobranza"/>
                    <field name="cobranza_real_actual"/>
                    <field name="progreso_cobranza_pct"/>
                    <field name="comision_proyectada"/>
                    
                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click" style="border-radius: 12px; padding: 20px; background: white; box-shadow: 0px 4px 12px rgba(0,0,0,0.08); display: flex; flex-direction: column; height: 100%;">
                                
                                <!-- Header -->
                                <div class="o_kanban_record_top" style="margin-bottom: 15px;">
                                    <div class="o_kanban_record_headings" style="text-align: center; width: 100%;">
                                        <h3 style="margin: 0; color: #2C3E50; font-weight: 700;">
                                            <t t-if="record.vendedor_id.raw_value"><field name="vendedor_id"/></t>
                                            <t t-else="">Mi Progreso Mensual</t>
                                        </h3>
                                        <small style="color: #7F8C8D;">Desempeño del Empleado</small>
                                    </div>
                                </div>

                                <!-- Body: Gráficos de Dona -->
                                <div class="o_kanban_record_body d-flex justify-content-around mt-3" style="flex: 1;">
                                    
                                    <!-- Dona Ventas -->
                                    <t t-set="pct_v" t-value="record.progreso_venta_pct.raw_value or 0"/>
                                    <!-- Verdecito si alcanzó 100%, naranja oscuro si está en progreso -->
                                    <t t-set="color_v" t-value="pct_v &gt;= 100 ? '#28a745' : '#FD7E14'"/>
                                    <!-- Limitar anillo al 100% mecánicamente para el gráfico CSS -->
                                    <t t-set="draw_v" t-value="pct_v > 100 ? 100 : pct_v"/>
                                    
                                    <div class="d-flex flex-column align-items-center">
                                        <div t-attf-style="width: 100px; height: 100px; border-radius: 50%; background: conic-gradient({{color_v}} {{draw_v}}%, #e9ecef 0); display: flex; align-items: center; justify-content: center;">
                                            <div style="width: 76px; height: 76px; background-color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-direction: column;">
                                                <span style="font-size: 16px; font-weight: bold; color: #333;"><t t-esc="Math.floor(pct_v)"/>%</span>
                                            </div>
                                        </div>
                                        <div class="mt-2 text-center">
                                            <span style="font-size: 11px; font-weight: bold; text-transform: uppercase;">Ventas</span><br/>
                                            <span style="font-size: 12px; color: #666;"><field name="venta_real_actual"/> / <field name="meta_venta"/></span>
                                        </div>
                                    </div>

                                    <!-- Dona Cobranza -->
                                    <t t-set="pct_c" t-value="record.progreso_cobranza_pct.raw_value or 0"/>
                                    <t t-set="color_c" t-value="pct_c &gt;= 100 ? '#28a745' : '#007BFF'"/>
                                    <t t-set="draw_c" t-value="pct_c > 100 ? 100 : pct_c"/>
                                    
                                    <div class="d-flex flex-column align-items-center">
                                        <div t-attf-style="width: 100px; height: 100px; border-radius: 50%; background: conic-gradient({{color_c}} {{draw_c}}%, #e9ecef 0); display: flex; align-items: center; justify-content: center;">
                                            <div style="width: 76px; height: 76px; background-color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-direction: column;">
                                                <span style="font-size: 16px; font-weight: bold; color: #333;"><t t-esc="Math.floor(pct_c)"/>%</span>
                                            </div>
                                        </div>
                                        <div class="mt-2 text-center">
                                            <span style="font-size: 11px; font-weight: bold; text-transform: uppercase;">Cobranza</span><br/>
                                            <span style="font-size: 12px; color: #666;"><field name="cobranza_real_actual"/> / <field name="meta_cobranza"/></span>
                                        </div>
                                    </div>

                                </div>

                                <!-- Footer: Resumen -->
                                <div class="o_kanban_record_bottom mt-4" style="border-top: 1px solid #eee; padding-top: 12px; display: flex; justify-content: space-between; align-items: center;">
                                    <div class="o_label">
                                        <span style="font-size: 12px; color: #7F8C8D;">Comisión Proyectada</span>
                                    </div>
                                    <div class="o_value">
                                        <span style="font-size: 18px; font-weight: bold; color: #27AE60;">
                                            <field name="comision_proyectada"/>
                                        </span>
                                    </div>
                                </div>

                                <!-- Nuevo Botón de Liquidación Mágica -->
                                <div class="mt-3" style="text-align: center;">
                                    <button type="object" name="action_open_calculo_comision" class="btn btn-sm btn-outline-primary w-100" style="border-radius: 20px; font-weight: bold;">
                                        Liquidar / Ver Detalles
                                    </button>
                                </div>

                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Dashboard Action -->
        <record id="action_dashboard_comision" model="ir.actions.act_window">
            <field name="name">Dashboard de Comisiones</field>
            <field name="res_model">meta.vendedor</field>
            <field name="view_mode">kanban</field>
            <field name="search_view_id" ref="view_dashboard_comision_search"/>
            <!-- Activar filtro por defecto -->
            <field name="context">{'search_default_current_month': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aún no hay metas asignadas para el mes en curso.
                </p>
                <p>
                    Las metas del mes vigente aparecerán aquí para realizar el seguimiento en vivo.
                </p>
            </field>
        </record>

        <!-- Menu Item para Dashboard -->
        <menuitem id="menu_dashboard_comision"
                  name="Dashboard"
                  parent="menu_calculo_comisiones_root"
                  action="action_dashboard_comision"
                  sequence="5"/>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Herencia vista de listado (Tree View) -->
    <record id="view_account_payment_tree_inherit_comisiones" model="ir.ui.view">
        <field name="name">account.payment.tree.inherit.comisiones</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="vendedor_id" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Herencia vista de formulario (Form View) -->
    <record id="view_account_payment_form_inherit_comisiones" model="ir.ui.view">
        <field name="name">account.payment.form.inherit.comisiones</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="vendedor_id" invisible="payment_type != 'inbound'"/>
            </xpath>
        </field>
    </record>
</odoo>

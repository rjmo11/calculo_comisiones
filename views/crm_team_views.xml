<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="crm_team_view_form_inherit_comisiones" model="ir.ui.view">
        <field name="name">crm.team.form.inherit.comisiones</field>
        <field name="model">crm.team</field>
        <field name="inherit_id" ref="sales_team.crm_team_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='user_id']" position="after">
                <field name="team_type" widget="radio" options="{'horizontal': true}"/>
            </xpath>
        </field>
    </record>
</odoo>

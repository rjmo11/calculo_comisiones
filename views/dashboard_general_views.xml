<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista de Lista Independiente para las líneas del Dashboard -->
    <record id="view_comision_dashboard_vendedor_list" model="ir.ui.view">
        <field name="name">comision.dashboard.vendedor.list</field>
        <field name="model">comision.dashboard.vendedor</field>
        <field name="arch" type="xml">
            <list create="0" delete="0" decoration-info="es_supervisor" limit="20">
                <field name="es_supervisor" column_invisible="True"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="vendedor_id" widget="many2one_avatar_user" string="Persona"/>
                <field name="rol_label" string="Rol" widget="badge" decoration-info="es_supervisor" decoration-success="not es_supervisor"/>
                <field name="meta_venta" string="Meta Asignada"/>
                <field name="venta_lograda" string="Logro Período"/>
                <field name="progreso_porcentaje" string="Avance" widget="progressbar"/>
                <field name="bono_estimado" string="Bono Estimado" widget="monetary"/>
            </list>
        </field>
    </record>

    <!-- Vista Maestra del Dashboard (Formulario Trucado) -->
    <record id="view_comision_dashboard_general_form" model="ir.ui.view">
        <field name="name">comision.dashboard.general.form</field>
        <field name="model">comision.dashboard.general</field>
        <field name="arch" type="xml">
            <form string="Control de Mandos" create="0" delete="0">
                <!-- Escondemos la botonera del form con un CSS oculto si deseamos, 
                     o la aprovechamos interactiva -->
                <sheet>
                    <field name="cumplimiento_general" invisible="1"/>
                    <field name="currency_id" invisible="1"/>
                    
                    <style>
                        .kpi-card-value {
                            font-size: clamp(2.2rem, 5vw, 2.8rem) !important;
                            font-weight: 700 !important;
                            letter-spacing: -1.2px;
                            white-space: nowrap;
                            display: flex;
                            justify-content: center;
                            align-items: baseline;
                            line-height: 1;
                        }
                        
                        /* Ensure widgets inside card cells inherit the consistent font size */
                        .kpi-card-value .o_field_widget {
                            font-size: inherit !important;
                            font-weight: inherit !important;
                            border-bottom: none !important;
                        }

                        /* Fix Odoo monetary and percentage widget internal flex */
                        .kpi-card-value .o_field_monetary, 
                        .kpi-card-value .o_field_percentage {
                            display: inline-flex !important;
                            align-items: baseline;
                            text-decoration: none !important;
                        }

                        /* Global Symbol Styling (Bs.F, %) - Solid and clear */
                        .kpi-card-value .o_field_monetary span:not(.oe_currency_value),
                        .kpi-card-value span.o_percentage_symbol,
                        .kpi-card-value .o_field_percentage span:not(.oe_percentage_value) {
                            font-size: 0.5em !important;
                            font-weight: 500 !important;
                            margin-left: 8px !important;
                            opacity: 1 !important;
                            transform: translateY(-0.15em);
                        }

                        .kpi-card-title {
                            font-size: 0.85rem !important;
                            letter-spacing: 1.5px !important;
                            color: #333 !important;
                            font-weight: 700 !important;
                            text-transform: uppercase;
                            margin-bottom: 1rem;
                        }
                    </style>
                    
                    <!-- ENCABEZADO Y FILTROS -->
                    <div class="row align-items-center mb-4 pb-3" style="border-bottom: 2px solid #eee;">
                        <div class="col-8">
                            <h1 class="text-primary fw-bold" style="font-size: 2.2rem; letter-spacing: -1px;">
                                <i class="fa fa-tachometer me-2"/> Panel de Control: Comisiones
                            </h1>
                        </div>
                        <div class="col-4 text-end">
                            <!-- Filtro de Equipo que recarga todo vía onchange -->
                            <field name="equipo_filter" widget="radio" options="{'horizontal': true}" class="fw-bold"/>
                        </div>
                    </div>

                    <!-- TARJETAS KPI (USANDO INVISIBLE CONDICIONAL PARA LOS GATILLOS DE COLORES) -->
                    <div class="row text-center mb-5">
                        <!-- KPI 1 Facturado -->
                        <div class="col-3">
                            <div class="card shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #0dcaf0; background: #fafafa;">
                                <div class="card-body py-4">
                                    <h6 class="kpi-card-title fw-bold mb-2">Total Facturado Mes</h6>
                                    <div class="kpi-card-value text-dark"><field name="total_facturado" widget="monetary" options="{'precision': 0}" readonly="1"/></div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- KPI 2 Cobrado -->
                        <div class="col-3">
                            <div class="card shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #20c997; background: #fafafa;">
                                <div class="card-body py-4">
                                    <h6 class="kpi-card-title fw-bold mb-2">Total Cobrado Mes</h6>
                                    <div class="kpi-card-value text-dark"><field name="total_cobrado" widget="monetary" options="{'precision': 0}" readonly="1"/></div>
                                </div>
                            </div>
                        </div>

                        <!-- KPI 3 RENDIMIENTO (TARJETAS DINÁMICAS POR RENDIMIENTO) -->
                        <div class="col-3">
                            <!-- ROJO: < 90% -->
                            <div class="card shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #dc3545; background-color: #fdf5f6;" invisible="cumplimiento_general &gt;= 90">
                                <div class="card-body py-4">
                                    <h6 class="text-danger text-uppercase fw-bold mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Porcentaje de Cumplimiento</h6>
                                    <div class="kpi-card-value text-danger"><field name="cumplimiento_general" widget="percentage" options="{'digits': [16, 1]}" readonly="1"/></div>
                                </div>
                            </div>
                            <!-- AMARILLO: 90% - 99% -->
                            <div class="card shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #ffc107; background-color: #fffdf5;" invisible="cumplimiento_general &lt; 90 or cumplimiento_general &gt;= 100">
                                <div class="card-body py-4">
                                    <h6 class="text-warning text-uppercase fw-bold mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Rendimiento Aceptable</h6>
                                    <div class="kpi-card-value text-warning"><field name="cumplimiento_general" widget="percentage" options="{'digits': [16, 1]}" readonly="1"/></div>
                                </div>
                            </div>
                            <!-- VERDE: >= 100% -->
                            <div class="card shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #198754; background-color: #f5fdf7;" invisible="cumplimiento_general &lt; 100">
                                <div class="card-body py-4">
                                    <h6 class="text-success text-uppercase fw-bold mb-2" style="font-size: 0.8rem; letter-spacing: 1px;">Meta Superada</h6>
                                    <div class="kpi-card-value text-success"><field name="cumplimiento_general" widget="percentage" options="{'digits': [16, 1]}" readonly="1"/></div>
                                </div>
                            </div>
                        </div>

                        <!-- KPI 4 Bonos -->
                        <div class="col-3">
                            <div class="card shadow-sm h-100" style="border-radius: 12px; border-top: 5px solid #6f42c1; background: #fafafa;">
                                <div class="card-body py-4">
                                    <h6 class="kpi-card-title fw-bold mb-2">Desembolso Proyectado</h6>
                                    <div class="kpi-card-value" style="color: #6f42c1;"><field name="bono_total_estimado" widget="monetary" options="{'precision': 0}" readonly="1"/></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- GRÁFICO HORIZONTAL VS BARRAS -->
                    <div class="row mb-3 mt-5">
                        <div class="col-12">
                            <h3 class="fw-bold mb-3" style="border-bottom: 2px solid #333; padding-bottom: 8px;">
                                <i class="fa fa-bar-chart me-2"/> Gráfico Comparativo: Metas vs Logros (Ventas)
                            </h3>
                            <field name="desglose_vendedores_ids" nolabel="1" context="{'tree_view_ref': 'calculo_comisiones.view_comision_dashboard_vendedor_list'}"/>
                        </div>
                    </div>
                    
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACCIÓN SERVIDOR PARA INVOCAR EL DASHBOARD TRANSIENTE -->
    <!-- En lugar de cargar una vista vacia, un python action crea el singleton al vuelo -->
    <record id="action_dashboard_gerencial_server" model="ir.actions.server">
        <field name="name">Vista Gerencial</field>
        <field name="model_id" ref="calculo_comisiones.model_comision_dashboard_general"/>
        <field name="state">code</field>
        <field name="code">
# Invocamos el método maestro para crear el dashboard con seguridad
act = env['comision.dashboard.general'].action_get_dashboard()
action = {
    'type': 'ir.actions.act_window',
    'name': 'Tablero de Control',
    'res_model': 'comision.dashboard.general',
    'res_id': act.id,
    'view_mode': 'form',
    'target': 'current',
    'context': {'create': False, 'edit': True}
}
        </field>
    </record>

    <!-- REEMPLAZO DE MENÚ -->
    <!-- Insertamos el nuevo Dashboard Gerencial arriba de los cálculos -->
    <menuitem id="menu_dashboard_gerencial_root"
              name="Dashboard Gerencial"
              parent="menu_calculo_comisiones_root"
              action="action_dashboard_gerencial_server"
              sequence="1"/>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_calculo_comision_tree" model="ir.ui.view">
        <field name="name">calculo.comision.tree</field>
        <field name="model">calculo.comision</field>
        <field name="arch" type="xml">
            <list string="Cálculos de Comisión" decoration-info="state == 'draft'" decoration-warning="state == 'calculated'" decoration-success="state == 'approved'">
                <field name="name"/>
                <field name="vendedor_id"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="currency_id" column_invisible="True"/>
                <field name="total_a_pagar" sum="Total"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'calculated'" decoration-success="state == 'approved'"/>
            </list>
        </field>
    </record>

    <record id="view_calculo_comision_form" model="ir.ui.view">
        <field name="name">calculo.comision.form</field>
        <field name="model">calculo.comision</field>
        <field name="arch" type="xml">
            <form string="Cálculo de Comisión">
                <header>
                    <button name="action_procesar_calculo" string="Calcular" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Aprobar" type="object" class="oe_highlight" invisible="state != 'calculated'"/>
                    <button name="action_draft" string="Volver a Borrador" type="object" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,calculated,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <field name="currency_id" invisible="1"/>
                    <group>
                        <group>
                            <field name="vendedor_id" readonly="state != 'draft'"/>
                            <field name="modo_periodo" widget="radio" options="{'horizontal': true}" readonly="state != 'draft'"/>
                            <field name="quincena_elegida" widget="radio" options="{'horizontal': true}" invisible="modo_periodo != 'quincenal'" readonly="state != 'draft'"/>
                            <field name="tipo_periodo" invisible="1"/>
                            <field name="meta_id" context="{'default_vendedor_id': vendedor_id}" 
                                   domain="[('vendedor_id', '=', vendedor_id), ('state', '=', 'active')]"
                                   readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="fecha_inicio" readonly="state != 'draft'" invisible="modo_periodo != 'personalizado'"/>
                            <field name="fecha_fin" readonly="state != 'draft'" invisible="modo_periodo != 'personalizado'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Resultados y Liquidación" name="resultados">
                            <group>
                                <group string="Ventas">
                                    <field name="meta_venta" widget="monetary" string="Meta Venta Mensual"/>
                                    <field name="meta_venta_aplicada" widget="monetary" string="Meta Venta del Periodo" invisible="not meta_venta_aplicada"/>
                                    <field name="venta_real_monto" widget="monetary"/>
                                    <field name="porcentaje_cumplimiento_v" widget="percentage"/>
                                    <field name="bono_base_venta" widget="monetary" string="Bono Base Venta Mensual"/>
                                    <field name="bono_base_venta_aplicado" widget="monetary" string="Bono Base Venta del Periodo" invisible="not bono_base_venta_aplicado"/>
                                    <field name="monto_bono_venta" widget="monetary" string="Bono Venta Logrado"/>
                                </group>
                                <group string="Cobranzas">
                                    <field name="meta_cobranza" widget="monetary" string="Meta Cobranza Mensual"/>
                                    <field name="meta_cobranza_aplicada" widget="monetary" string="Meta Cobranza del Periodo" invisible="not meta_cobranza_aplicada"/>
                                    <field name="cobranza_real_monto" widget="monetary"/>
                                    <field name="porcentaje_cumplimiento_c" widget="percentage"/>
                                    <field name="bono_base_cobranza" widget="monetary" string="Bono Base Cobranza Mensual"/>
                                    <field name="bono_base_cobranza_aplicado" widget="monetary" string="Bono Base Cobranza del Periodo" invisible="not bono_base_cobranza_aplicado"/>
                                    <field name="monto_bono_cobranza" widget="monetary" string="Bono Cobranza Logrado"/>
                                </group>
                            </group>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="importe_adelanto" widget="monetary" invisible="importe_adelanto == 0"/>
                                <div class="oe_subtotal_footer_separator oe_inline o_td_label" invisible="importe_adelanto == 0">
                                    <label for="total_a_pagar"/>
                                </div>
                                <field name="total_a_pagar" widget="monetary" class="oe_subtotal_footer_separator" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Detalle de Facturas" name="facturas">
                            <field name="factura_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="invoice_date"/>
                                    <field name="amount_untaxed" sum="Total Base"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Detalle de Pagos" name="pagos">
                            <field name="pago_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="date"/>
                                    <field name="amount" sum="Total Cobrado"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <!-- Chatter -->
                <div class="oe_chatter">
                    <separator string="Historial y Actividades del Documento"/>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_calculo_comision" model="ir.actions.act_window">
        <field name="name">Cálculo de Comisiones</field>
        <field name="res_model">calculo.comision</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea un nuevo cálculo de comisión
            </p>
        </field>
    </record>

    <!-- Menú -->
    <menuitem id="menu_calculo_comision" 
              name="Cálculos" 
              parent="menu_calculo_comisiones_root" 
              action="action_calculo_comision" 
              sequence="20"/>
</odoo>
